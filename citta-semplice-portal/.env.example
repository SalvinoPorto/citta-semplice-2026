# Environment Variables for Città Semplice Application
NEXT_PUBLIC_BASE_PATH=

# Database
DATABASE_URL=

# NextAuth
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# JWT
JWT_EXPIRATION_HOURS=

# File Storage
UPLOAD_DIR=
MODULES_DIR=

# Urbi SMART - Protocollo
URBI_BASE_URL=
URBI_USERNAME=
URBI_PASSWORD=
URBI_ID_AOO=
URBI_TIPO_MEZZO=
URBI_CLASSIFICAZIONE=
URBI_REGISTRATORE=
URBI_TIMEOUT_MS=
PROTOCOL_FALLBACK_PREFIX=

# PmPay — PagoPA
# Test:  https://service.pmpay.it/pagoparest
# Prod:  https://secure.pmpay.it/pagoparest
PMPAY_URL=
PMPAY_USERNAME=
PMPAY_PASSWORD=
PMPAY_ENTE_ID=
PMPAY_TIMEOUT_MS=
# URL di redirect dopo il pagamento online (lasciate vuote usano NEXTAUTH_URL/pagamento/ok|ko|annullato)
PMPAY_URL_OK=
PMPAY_URL_KO=
PMPAY_URL_CANCEL=

# Cron Jobs (enable/disable)
ENABLE_CRON_JOBS=

# CIG SSO — SPID/CIE (Comune di Catania)
CIG_SSO_URL=
CIG_SECRET_KEY=
CIG_STYLESHEET=
CIG_LOGO_URL=
