generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTHENTICATION & USERS
// ============================================

model Operatore {
  id                Int       @id @default(autoincrement())
  email             String    @db.VarChar(100)
  password          String    @db.VarChar(64)
  nome              String    @db.VarChar(100)
  cognome           String    @db.VarChar(100)
  userName          String    @db.VarChar(64) @unique @map("user_name")
  telefono          String?   @db.VarChar(255)
  attivo            Boolean   @default(true)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  ufficioId         Int?      @map("ufficio_id")
  ufficio           Ufficio?  @relation(fields: [ufficioId], references: [id], onDelete: SetNull)

  // Relations
  ruoli             OperatoreRuolo[]
  workflows         Workflow[]
  comunicazioni     Comunicazione[]
  workflowFasiCompletati  WorkflowFase[]

  @@index([userName])
  @@map("operatori")
}

model Ruolo {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  descrizione String?
  permessi    String[]  @default([])

  operatori   OperatoreRuolo[]

  @@map("ruoli")
}

model OperatoreRuolo {
  operatoreId Int       @map("operatore_id")
  ruoloId     Int       @map("ruolo_id")

  operatore   Operatore @relation(fields: [operatoreId], references: [id], onDelete: Cascade)
  ruolo       Ruolo     @relation(fields: [ruoloId], references: [id], onDelete: Cascade)

  @@id([operatoreId, ruoloId])
  @@map("operatori_ruoli")
}

model RuoloUser {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  descrizione String?   @db.VarChar(100)

  servizi      ServizioRuoloUser[]

  @@map("ruoli_user")
}

// ============================================
// ORGANIZATION STRUCTURE
// ============================================

model Ente {
  id              Int       @id @default(autoincrement())
  nome            String    @db.VarChar(255)
  descrizione     String?   @db.VarChar(255)
  sede            String?   @db.VarChar(255)
  codice          String?   @db.VarChar(255)
  indirizzo       String?   @db.VarChar(255)
  telefono        String?   @db.VarChar(255)
  email           String?   @db.VarChar(255)
  pec             String?   @db.VarChar(255)
  logo            String?   @db.VarChar(255)
  attivo          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("enti")
}

model Area {
  id          Int       @id @default(autoincrement())
  nome        String    @db.VarChar(255)
  descrizione String?   @db.VarChar(512)
  icona       String?   @db.VarChar(255)
  ordine      Int       @default(0)
  attiva      Boolean   @default(true)
  slug        String    @db.VarChar(255) @default("\/") @unique
  privata     Boolean   @default(false)
  
  servizi     Servizio[]

  @@map("aree")
}

model Servizio {
  id          Int       @id @default(autoincrement())
  titolo      String    @db.Text
  sottoTitolo String?   @db.Text @map("sotto_titolo")
  descrizione String?   @db.Text
  comeFare    String?   @map("come_fare")
  cosaServe   String?   @map("cosa_serve")
  altreInfo   String?   @map("altre_info")
  contatti    String?
  slug        String    @db.VarChar(255) @default("\/") @unique
  icona       String?   @db.VarChar(255)
  ordine      Int       @default(0)
  attivo      Boolean   @default(true)

  areaId      Int       @map("area_id")
  area        Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)

  attributi                 String?   @db.Text @map("attributi") // JSON form schema
  moduloCorpo               String?   @db.Text @map("modulo_corpo")
  postFormValidation        Boolean   @default(false) @map("post_form_validation")
  postFormValidationAPI     String?   @db.VarChar(255) @map("post_form_validation_api")
  postFormValidationFields  String?   @db.VarChar(255) @map("post_form_validation_fields")

  ufficioId   Int?      @map("ufficio_id")
  ufficio     Ufficio?  @relation(fields: [ufficioId], references: [id], onDelete: SetNull)

  // Disponibilità
  dataInizio  DateTime? @map("data_inizio")
  dataFine    DateTime? @map("data_fine")

  // Regole di invio
  unicoInvio            Boolean   @default(false) @map("unico_invio")
  unicoInvioPerUtente   Boolean   @default(false) @map("unico_invio_per_utente")
  campiUnicoInvio       String?   @map("campi_unico_invio")
  numeroMaxIstanze      Int?      @default(0) @map("numero_max_istanze")
  msgSopraSoglia        String?   @db.VarChar(300) @map("msg_sopra_soglia")
  msgExtraServizio      String?   @db.VarChar(500) @map("msg_extra_servizio")

  // Visualizzazione istanze
  campiInEvidenza       String?   @map("campi_in_evidenza")
  campiDaEsportare      String?   @map("campi_da_esportare")

  evidenza              Boolean   @default(false)
  // Documento finale
  //prevedeDocumentoFinale    Boolean   @default(false) @map("prevede_documento_finale")
  //templateDocumentoFinale   String?   @db.VarChar(255) @map("template_documento_finale") @db.Text
  //nomeDocumentoFinale       String?   @db.VarChar(255) @map("nome_documento_finale")

  createdAt             DateTime? @default(now()) @map("created_at")
  updatedAt             DateTime? @map("updated_at")
  
  steps                 Step[]
  istanze               Istanza[]
  customerSatisfaction  CustomerSatisfaction?
  ricevuta              Ricevuta?
  ruoli                 ServizioRuoloUser[]
  fasi                  Fase[]

  @@map("servizi")
}

model Ufficio {
  id          Int       @id @default(autoincrement())
  nome        String    @db.VarChar(255)
  descrizione String?   @db.VarChar(255)
  email       String?   @db.VarChar(255)
  telefono    String?   @db.VarChar(255)
  indirizzo   String?   @db.VarChar(255)
  attivo      Boolean   @default(true)

  servizi              Servizio[]
  fasi                 Fase[]
  operatori            Operatore[]
  istanzeUfficioCorrente Istanza[] @relation("UfficioCorrente")

  @@map("uffici")
}


model ServizioRuoloUser {
  servizioId  Int       @map("servizio_id")
  ruoloUserId Int       @map("ruolo_user_id")

  servizio    Servizio  @relation(fields: [servizioId], references: [id], onDelete: Cascade)
  ruoloUser   RuoloUser @relation(fields: [ruoloUserId], references: [id], onDelete: Cascade)

  @@id([servizioId, ruoloUserId])
  @@map("servizi_ruoli_user")
}

// ============================================
// WORKFLOW STEPS
// ============================================

model Step {
  id                          Int       @id @default(autoincrement())
  descrizione                 String
  ordine                      Int
  attivo                      Boolean   @default(true)

  // Features
  pagamento                   Boolean   @default(false)
  allegati                    Boolean   @default(false)
  allegatiOp                  Boolean   @default(false) @map("allegati_op")
  allegatiRequired            Boolean   @default(false) @map("allegati_required")
  allegatiOpRequired          Boolean   @default(false) @map("allegati_op_required")
  /*
  allegatiRichiesti           String?   @map("allegati_richiesti")
  allegatiOpRichiesti         String?   @map("allegati_op_richiesti")
  */
  // Protocol
  protocollo                  Boolean   @default(false)
  tipoProtocollo              String?   @db.VarChar(1) @map("tipo_protocollo") // 'E' = Entrata, 'U' = Uscita
  unitaOrganizzativa          String?   @db.VarChar(512) @map("unita_organizzativa")
  numerazioneInterna          Boolean   @default(false) @map("numerazione_interna")

  // Assignment
  assegnabileASpecificoUfficio Boolean  @default(false) @map("assegnabile_a_specifico_ufficio")
  settaAttributo              Boolean   @default(false) @map("setta_attributo")

  servizioId                  Int       @map("servizio_id")
  servizio                    Servizio  @relation(fields: [servizioId], references: [id], onDelete: Cascade)

  faseId                      Int?      @map("fase_id")
  fase                        Fase?     @relation(fields: [faseId], references: [id], onDelete: SetNull)

  workflows                   Workflow[]
  allegatiRichiestiList       AllegatoRichiesto[]
  pagamentoConfig             Pagamento?

  //@@unique([servizioId, ordine])
  @@map("steps")
}


model AllegatoRichiesto {
  id                  Int       @id @default(autoincrement())
  nomeAllegatoRichiesto String  @db.VarChar(512) @map("nome_allegato_richiesto")
  obbligatorio        Boolean   @default(false)
  interno             Boolean   @default(false)
  soggetto            String?   @db.VarChar(2) // OP = Operatore, UT = Utente

  stepId              Int?      @map("step_id")
  step                Step?     @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("allegati_richiesti")
}

// ============================================
// USERS (Citizens)
// ============================================

model Utente {
  id              Int       @id @default(autoincrement())
  codiceFiscale   String    @unique @map("codice_fiscale")
  nome            String
  cognome         String
  email           String?
  telefono        String?
  dataNascita     DateTime? @map("data_nascita")
  luogoNascita    String?   @map("luogo_nascita")
  indirizzo       String?
  cap             String?
  citta           String?
  provincia       String?
  pec             String?
  createdAt       DateTime  @default(now()) @map("created_at")

  istanze         Istanza[]

  @@map("utenti")
}

// ============================================
// INSTANCES (ISTANZE) - Requests
// ============================================

model Istanza {
  id                  Int       @id @default(autoincrement())
  dati                String?   @db.Text // JSON form data
  datiInEvidenza      String?   @map("dati_in_evidenza")
  datiResponso        String?   @map("dati_responso") @db.Text
  municipalita        String?   @db.VarChar(60)

  // Status
  conclusa            Boolean   @default(false)
  respinta            Boolean   @default(false)
  inBozza             Boolean   @default(false) @map("in_bozza")
  activeStep          Int?      @map("active_step")

  // Protocol
  protoNumero         String    @db.VarChar(50) @map("proto_numero")
  protoData           DateTime? @map("proto_data")
  protoFinaleNumero   String?   @db.VarChar(50) @map("proto_finale_numero")
  protoFinaleData     DateTime? @map("proto_finale_data")

  // Dates
  dataInvio           DateTime  @map("data_invio")
  createdAt           DateTime  @default(now()) @map("created_at")

  // Bulk send
  //invioMassivo        String?   @map("invio_massivo")
  //msgInvioMassivo     String?   @map("msg_invio_massivo")

  // Relations
  utenteId            Int       @map("utente_id")
  utente              Utente    @relation(fields: [utenteId], references: [id])

  servizioId          Int       @map("servizio_id")
  servizio            Servizio  @relation(fields: [servizioId], references: [id])

  lastStepId          Int?      @map("last_step_id")

  faseCorrenteId      Int?      @map("fase_corrente_id")
  faseCorrente        Fase?     @relation("FaseCorrente", fields: [faseCorrenteId], references: [id], onDelete: SetNull)

  ufficioCorrenteId   Int?      @map("ufficio_corrente_id")
  ufficioCorrente     Ufficio?  @relation("UfficioCorrente", fields: [ufficioCorrenteId], references: [id], onDelete: SetNull)

  workflows           Workflow[]
  comunicazioni       Comunicazione[]
  workflowFasi        WorkflowFase[]

  @@index([utenteId])
  @@index([servizioId])
  @@index([dataInvio])
  @@index([protoNumero])
  @@map("istanze")
}

// ============================================
// WORKFLOW
// ============================================

model Workflow {
  id              Int       @id @default(autoincrement())
  note            String?   @db.Text
  dataVariazione  DateTime  @map("data_variazione")

  // Relations
  istanzaId       Int       @map("istanza_id")
  istanza         Istanza   @relation(fields: [istanzaId], references: [id], onDelete: Cascade)

  stepId          Int       @map("step_id")
  step            Step?     @relation(fields: [stepId], references: [id])

  stato           Int       @default(0)
  operatoreId     Int?      @map("operatore_id")
  operatore       Operatore? @relation(fields: [operatoreId], references: [id])

  allegati            Allegato[]
  pagamentoAtteso PagamentoAtteso?

  @@index([istanzaId])
  @@index([dataVariazione])
  @@map("workflows")
}

model Fase {
  id          Int      @id @default(autoincrement())
  nome        String   @db.VarChar(255)
  ordine      Int

  servizioId  Int      @map("servizio_id")
  servizio    Servizio @relation(fields: [servizioId], references: [id], onDelete: Cascade)

  ufficioId        Int?     @map("ufficio_id")
  ufficio          Ufficio? @relation(fields: [ufficioId], references: [id], onDelete: SetNull)

  steps                Step[]
  workflowFasi         WorkflowFase[]
  istanzeFaseCorrente  Istanza[]      @relation("FaseCorrente")

  @@map("fasi")
}

model WorkflowFase {
  id                       Int       @id @default(autoincrement())
  dataInizio               DateTime  @map("data_inizio")
  dataCompletamento        DateTime? @map("data_completamento")
  direzione                String    @default("AVANZAMENTO") @db.VarChar(20)

  istanzaId                Int       @map("istanza_id")
  istanza                  Istanza   @relation(fields: [istanzaId], references: [id], onDelete: Cascade)

  faseId                   Int       @map("fase_id")
  fase                     Fase      @relation(fields: [faseId], references: [id])

  operatoreCompletamentoId Int?      @map("operatore_completamento_id")
  operatoreCompletamento   Operatore? @relation(fields: [operatoreCompletamentoId], references: [id])

  @@index([istanzaId])
  @@map("workflow_fasi")
}

model Comunicazione {
  id                Int       @id @default(autoincrement())
  testo             String    @db.Text
  richiedeRisposta  Boolean   @default(false) @map("richiede_risposta")
  allegatiRichiesti String?   @db.Text @map("allegati_richiesti") // JSON: [{nome: string, obbligatorio: boolean}]
  dataCreazione     DateTime  @default(now()) @map("data_creazione")

  istanzaId         Int       @map("istanza_id")
  istanza           Istanza   @relation(fields: [istanzaId], references: [id], onDelete: Cascade)

  operatoreId       Int?      @map("operatore_id")
  operatore         Operatore? @relation(fields: [operatoreId], references: [id])

  risposta          RispostaComunicazione?

  @@index([istanzaId])
  @@map("comunicazioni")
}

model RispostaComunicazione {
  id              Int       @id @default(autoincrement())
  testo           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
 
  comunicazioneId Int       @unique @map("comunicazione_id")
  comunicazione   Comunicazione @relation(fields: [comunicazioneId], references: [id], onDelete: Cascade)

  allegati        AllegatoRisposta[]

  @@map("risposte_comunicazioni")
}

model AllegatoRisposta {
  id          Int       @id @default(autoincrement())
  nomeFile    String    @db.VarChar(512) @map("nome_file")
  nomeHash    String    @db.VarChar(512) @map("nome_hash")
  mimeType    String?   @db.VarChar(50) @map("mime_type")

  rispostaId  Int       @map("risposta_id")
  risposta    RispostaComunicazione @relation(fields: [rispostaId], references: [id], onDelete: Cascade)

  @@map("allegati_risposta")
}

// ============================================
// ATTACHMENTS
// ============================================

model Allegato {
  id                  Int       @id @default(autoincrement())
  nomeFile            String    @db.VarChar(512) @map("nome_file")
  nomeHash            String    @db.VarChar(512) @map("nome_hash")
  nomeFileRichiesto   String?   @db.VarChar(512) @map("nome_file_richiesto")
  mimeType            String?   @db.VarChar(50) @map("mime_type")
  invUtente           Boolean   @default(false) @map("inv_utente")
  visto               Boolean   @default(false)
  dataInserimento     DateTime? @map("data_inserimento")

  workflowId          Int       @map("workflow_id")
  workflow            Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("allegati")
}

model Pagamento {
  id                  Int       @id @default(autoincrement())
  importo             Float?
  importoVariabile    Boolean   @default(false) @map("importo_variabile")
  obbligatorio        Boolean   @default(false)
  tipologiaPagamento  String?   @map("tipologia_pagamento")
  causale             String?   @db.Text
  causaleVariabile    Boolean   @default(false) @map("causale_variabile")

  // codice del servizio/tributo configurato in PmPay
  codiceTributo       String?   @db.VarChar(30) @map("codice_tributo")
  descrizioneTributo  String?   @db.VarChar(512) @map("descrizione_tributo")

  stepId              Int       @unique @map("step_id")
  step                Step      @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("pagamenti")
}

model PagamentoAtteso {
  id                      Int       @id @default(autoincrement())
  iuv                     String?   @db.VarChar(100)
  numeroDocumento         String?   @db.VarChar(30) @map("numero_documento")
  importoTotale           Float     @map("importo_totale")
  stato                   String?   @db.VarChar(3)
  dataEmissione           DateTime? @map("data_emissione")
  dataScadenza            DateTime? @map("data_scadenza")
  dataOperazione          DateTime? @map("data_operazione")
  dataRicevuta            DateTime? @map("data_ricevuta")

  // Payment user info (può differire dall'utente istanza se pagatore terzo)
  paganteCodiceFiscale    String?   @db.VarChar(16) @map("pagante_codice_fiscale")
  pagante                 String?   @db.VarChar(50) 
  paganteEmail            String?   @db.VarChar(50) @map("pagante_email")
  causale                 String?   @db.VarChar(100) 

  workflowId          Int       @unique @map("workflow_id")
  workflow            Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("pagamenti_attesi")
}

// ============================================
// CUSTOMER SATISFACTION
// ============================================

model CustomerSatisfaction {
  id      Int       @id @default(autoincrement())
  green   Int       @default(0)
  yellow  Int       @default(0)
  red     Int       @default(0)
  gray    Int       @default(0)

  servizioId Int       @unique @map("servizio_id")
  servizio   Servizio  @relation(fields: [servizioId], references: [id], onDelete: Cascade)

  @@map("customer_satisfaction")
}

// ============================================
// RECEIPT (Ricevuta)
// Art. 18 bis L 241/1990 e L.R. 7/2019
// ============================================

model Ricevuta {
  id                              Int       @id @default(autoincrement())
  richiestaArt18                  Boolean   @default(false) @map("richiesta_art18")
  unitaOrganizzativaCompetente    String?   @db.Text @map("unita_organizzativa_competente")
  ufficioCompetente               String?   @db.Text @map("ufficio_competente")
  responsabileProcedimento        String?   @db.Text @map("responsabile_procedimento")
  durataMassimaProcedimento       Int?      @map("durata_massima_procedimento")
  responsabileProvvedimentoFinale String?   @db.Text @map("responsabile_provvedimento_finale")
  personaPotereSostitutivo        String?   @db.Text @map("persona_potere_sostitutivo")
  urlServizioWeb                  String?   @db.Text @map("url_servizio_web")
  ufficioRicevimento              String?   @db.Text @map("ufficio_ricevimento")

  servizioId      Int       @unique @map("servizio_id")
  servizio        Servizio  @relation(fields: [servizioId], references: [id], onDelete: Cascade)

  @@map("ricevute")
}

// ============================================
// EMERGENCY PROTOCOL
// ============================================

model ProtocolloEmergenzaCounter {
  anno        Int  @id
  progressivo Int  @default(0)

  @@map("protocollo_emergenza_counters")
}

model ProtocolloEmergenza {
  id          Int       @id @default(autoincrement())
  anno        Int       @default(0)
  progressivo Int       @default(0)
  data        DateTime  @default(now())
  tipo        String    // INGRESSO, USCITA
  rettificato Boolean   @default(false)
  istanzaId   Int?      @map("istanza_id")

  @@map("protocollo_emergenza")
}

// ============================================
// STATISTICS
// ============================================

model StatisticheGiornaliere {
  id                  Int       @id @default(autoincrement())
  data                DateTime  @db.Date
  istanzeInviate      Int       @default(0) @map("istanze_inviate")
  istanzeConcluse     Int       @default(0) @map("istanze_concluse")
  istanzeRespinte     Int       @default(0) @map("istanze_respinte")

  @@unique([data])
  @@map("statistiche_giornaliere")
}

model StatistichePagamenti {
  id                  Int       @id @default(autoincrement())
  data                DateTime  @db.Date
  numeroTransazioni   Int       @default(0) @map("numero_transazioni")
  importoTotale       Float     @default(0) @map("importo_totale")

  @@unique([data])
  @@map("statistiche_pagamenti")
}

// ============================================
// SYSTEM CONFIGURATION
// ============================================

model EmailConfig {
  id                  Int       @id @default(autoincrement())
  attivo              Boolean   @default(false)

  // Provider type: 'smtp' | 'office365'
  provider            String    @default("smtp")

  // SMTP Configuration
  smtpHost            String?   @db.VarChar(100) @map("smtp_host")
  smtpPort            Int?      @map("smtp_port")
  smtpSecure          Boolean   @default(false) @map("smtp_secure") // true = SSL/TLS
  smtpUser            String?   @db.VarChar(50) @map("smtp_user")
  smtpPassword        String?   @db.VarChar(64) @map("smtp_password")
  smtpFromEmail       String?   @db.VarChar(100) @map("smtp_from_email")
  smtpFromName        String?   @db.VarChar(100) @map("smtp_from_name")

  // Office 365 / Microsoft Graph API Configuration
  o365TenantId        String?   @db.VarChar(64) @map("o365_tenant_id")
  o365ClientId        String?   @db.VarChar(64) @map("o365_client_id")
  o365ClientSecret    String?   @db.VarChar(64) @map("o365_client_secret")
  o365SenderEmail     String?   @db.VarChar(100) @map("o365_sender_email")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("email_config")
}
