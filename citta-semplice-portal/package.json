  "description": "Portale dei servizi online a istanza di parte del Comune di Catania - Città Semplice",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node -e \"const fs=require('fs'),path=require('path');const src='node_modules/bootstrap-italia/dist/svg';const dst='public/bootstrap-italia/dist/svg';fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dst,f)));\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
