    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "bootstrap-italia": "^2.12.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^5.9.6",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "puppeteer": "^24.40.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "sonner": "^1.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
