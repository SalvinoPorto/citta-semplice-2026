{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Office: server (3000)",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/citta-semplice-office",
      "command": "npm run dev",
      "serverReadyAction": {
        "action": "startDebugging",
        "pattern": "- Local:.+(https?://.+)",
        "name": "Office: client"
      }
    },
    {
      "name": "Portal: server (3001)",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/citta-semplice-portal",
      "command": "npm run dev",
      "serverReadyAction": {
        "action": "startDebugging",
        "pattern": "- Local:.+(https?://.+)",
        "name": "Portal: client"
      }
    },
    {
      "name": "Office: client",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/citta-semplice-office",
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/citta-semplice-office/*"
      }
    },
    {
      "name": "Portal: client",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3001",
      "webRoot": "${workspaceFolder}/citta-semplice-portal",
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/citta-semplice-portal/*"
      }
    },
    {
      "name": "Office: attach to running dev",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "cwd": "${workspaceFolder}/citta-semplice-office",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Office + Portal (full stack)",
      "configurations": ["Office: server (3000)", "Portal: server (3001)"],
      "stopAll": true,
      "presentation": { "group": "app", "order": 1 }
    }
  ]
}
