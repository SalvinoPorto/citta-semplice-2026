{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Office: server (3000)",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/citta-semplice-office",
      "command": "npm run dev",
      "serverReadyAction": {
        "action": "startDebugging",
        "pattern": "- Local:.+:3000",
        "name": "Office: client"
      }
    },
    {
      "name": "Portal: server (3001)",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/citta-semplice-portal",
      "command": "npm run dev",
      "serverReadyAction": {
        "action": "startDebugging",
        "pattern": "- Local:.+:3001",
        "name": "Portal: client"
      }
    },
    {
      "name": "Office: client",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/citta-semplice-office",
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/citta-semplice-office/*"
      }
    },
    {
      "name": "Portal: client",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3001",
      "webRoot": "${workspaceFolder}/citta-semplice-portal",
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/citta-semplice-portal/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Office + Portal (full stack)",
      "configurations": [
        "Office: server (3000)",
        "Portal: server (3001)"
      ],
      "stopAll": true,
      "presentation": {
        "group": "app",
        "order": 1
      }
    }
  ]
}