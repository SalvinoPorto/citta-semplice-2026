{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "install (workspace root)",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "sync schema prisma",
      "type": "shell",
      "command": "./sync-schema.sh && npm run db:generate",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "build office + portal",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
