# Database
DATABASE_URL="postgresql://io_user:Comct2019@localhost:5432/io_db_2?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# JWT
JWT_EXPIRATION_HOURS=2

# File Storage
UPLOAD_DIR="/data/uploads"
MODULES_DIR="/data/modules"

# External Services — Urbi SMART (protocollazione)
# Endpoint base: https://{host}/{dir}/progs/main/xapirest.sto
URBI_BASE_URL="https://cloud.urbi.it/urbi/progs/main/xapirest.sto"
URBI_USERNAME=""
URBI_PASSWORD=""
URBI_ID_AOO="1"
URBI_TIPO_MEZZO="ISTANZA ONLINE"
URBI_CLASSIFICAZIONE="15"
URBI_REGISTRATORE=""
URBI_TIMEOUT_MS="30000"
# Prefisso per numerazione interna di emergenza (fallback quando Urbi non risponde)
PROTOCOL_FALLBACK_PREFIX="PE_"

PMPAY_URL="https://pmpay.example.com"
PMPAY_API_KEY=""
PMPAY_ENTE_ID=""

# Cron Jobs (enable/disable)
ENABLE_CRON_JOBS=false
