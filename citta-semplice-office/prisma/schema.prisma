model OperatoreServizio {
  operatoreId Int       @map("operatore_id")
  servizioId  Int       @map("servizio_id")

  operatore   Operatore @relation(fields: [operatoreId], references: [id], onDelete: Cascade)
  servizio    Servizio  @relation(fields: [servizioId], references: [id], onDelete: Cascade)

  @@id([operatoreId, servizioId])
  @@map("operatore_servizi")
}

model ServizioRuoloUser {
  servizioId  Int       @map("servizio_id")
  ruoloUserId Int       @map("ruolo_user_id")

  servizio    Servizio  @relation(fields: [servizioId], references: [id], onDelete: Cascade)
  ruoloUser   RuoloUser @relation(fields: [ruoloUserId], references: [id], onDelete: Cascade)

  @@id([servizioId, ruoloUserId])
  @@map("servizi_ruoli_user")
}

