generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

// ============================================
// AUTHENTICATION & USERS
// ============================================

model Operatore {
  id                Int       @id @default(autoincrement())
  email             String    
  password          String
  nome              String
  cognome           String
  userName          String   @unique @map("user_name")
  telefono          String?
  attivo            Boolean   @default(true)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  ruoli             OperatoreRuolo[]
  // enti              OperatoreEnte[]
  servizi           OperatoreServizio[]
  workflows         Workflow[]

  @@index([userName])
  @@map("operatori")
}

model Ruolo {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  descrizione String?
  permessi    String[]  @default([])

  operatori   OperatoreRuolo[]

  @@map("ruoli")
}

model OperatoreRuolo {
  operatoreId Int       @map("operatore_id")
  ruoloId     Int       @map("ruolo_id")

  operatore   Operatore @relation(fields: [operatoreId], references: [id], onDelete: Cascade)
  ruolo       Ruolo     @relation(fields: [ruoloId], references: [id], onDelete: Cascade)

  @@id([operatoreId, ruoloId])
  @@map("operatori_ruoli")
}

model RuoloUser {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  descrizione String?

  servizi      ServizioRuoloUser[]

  @@map("ruoli_user")
}

// ============================================
// ORGANIZATION STRUCTURE
// ============================================

model Ente {
  id              Int       @id @default(autoincrement())
  nome            String
  descrizione     String?
  codice          String?
  indirizzo       String?
  telefono        String?
  email           String?
  pec             String?
  logo            String?
  attivo          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  // aree            Area[]
  //operatori       OperatoreEnte[]
  //pagamenti       Pagamento[]

  @@map("enti")
}

