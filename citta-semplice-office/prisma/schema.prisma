// ============================================
// CUSTOMER SATISFACTION
// ============================================

model CustomerSatisfaction {
  id      Int       @id @default(autoincrement())
  green   Int       @default(0)
  yellow  Int       @default(0)
  red     Int       @default(0)
  gray    Int       @default(0)

  servizioId Int       @unique @map("servizio_id")
  servizio   Servizio  @relation(fields: [servizioId], references: [id], onDelete: Cascade)

  @@map("customer_satisfaction")
}

// ============================================
// RECEIPT (Ricevuta)
// ============================================

model Ricevuta {
  id                              Int       @id @default(autoincrement())
  // Art. 18 bis L 241/1990 e L.R. 7/2019
  richiestaArt18                  Boolean   @default(false) @map("richiesta_art18")
  unitaOrganizzativaCompetente    String?   @db.Text @map("unita_organizzativa_competente")
  ufficioCompetente               String?   @db.Text @map("ufficio_competente")
  responsabileProcedimento        String?   @db.Text @map("responsabile_procedimento")
  durataMassimaProcedimento       Int?      @map("durata_massima_procedimento")
  responsabileProvvedimentoFinale String?   @db.Text @map("responsabile_provvedimento_finale")
  personaPotereSostitutivo        String?   @db.Text @map("persona_potere_sostitutivo")
  urlServizioWeb                  String?   @db.Text @map("url_servizio_web")
  ufficioRicevimento              String?   @db.Text @map("ufficio_ricevimento")

  servizioId      Int       @unique @map("servizio_id")
  servizio        Servizio  @relation(fields: [servizioId], references: [id], onDelete: Cascade)

  @@map("ricevute")
}

