model Area {
  id          Int       @id @default(autoincrement())
  nome        String
  descrizione String?
  icona       String?
  ordine      Int       @default(0)
  attiva      Boolean   @default(true)
  slug        String    @db.VarChar(255) @default("\/") @unique
  privata     Boolean   @default(false)
  
  servizi     Servizio[]

  @@map("aree")
}

model Servizio {
  id          Int       @id @default(autoincrement())
  titolo      String    @db.VarChar(255)
  sottoTitolo String?   @db.VarChar(255) @map("sotto_titolo")
  descrizione String?
  comeFare    String?   @map("come_fare")
  cosaServe   String?   @map("cosa_serve")
  altreInfo   String?   @map("altre_info")
  contatti    String?
  slug        String    @db.VarChar(255) @default("\/") @unique
  icona       String?   @db.VarChar(255)
  ordine      Int       @default(0)
  attivo      Boolean   @default(true)

  areaId      Int       @map("area_id")
  area        Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)

  // Modulo (form dati richiedente, incorporato nel servizio)
  //moduloNomeFile          String?   @db.VarChar(255) @map("modulo_nome_file")
  attributi                 String?   @db.Text @map("attributi") // JSON form schema
  moduloCorpo               String?   @db.Text @map("modulo_corpo")
  postFormValidation        Boolean   @default(false) @map("post_form_validation")
  postFormValidationAPI     String?   @db.VarChar(255) @map("post_form_validation_api")
  postFormValidationFields  String?   @db.VarChar(255) @map("post_form_validation_fields")

  ufficioId   Int?      @map("ufficio_id")
  ufficio     Ufficio?  @relation(fields: [ufficioId], references: [id], onDelete: SetNull)

  // Disponibilità
  dataInizio  DateTime? @map("data_inizio")
  dataFine    DateTime? @map("data_fine")

  // Regole di invio
  unicoInvio            Boolean   @default(false) @map("unico_invio")
  unicoInvioPerUtente   Boolean   @default(false) @map("unico_invio_per_utente")
  campiUnicoInvio       String?   @map("campi_unico_invio")
  numeroMaxIstanze      Int?      @default(0) @map("numero_max_istanze")
  msgSopraSoglia        String?   @db.VarChar(300) @map("msg_sopra_soglia")
  msgExtraServizio      String?   @db.VarChar(500) @map("msg_extra_servizio")

  // Visualizzazione istanze
  campiInEvidenza       String?   @map("campi_in_evidenza")
  campiDaEsportare      String?   @map("campi_da_esportare")

  evidenza              Boolean   @default(false)
  // Documento finale
  //prevedeDocumentoFinale    Boolean   @default(false) @map("prevede_documento_finale")
  //templateDocumentoFinale   String?   @db.VarChar(255) @map("template_documento_finale") @db.Text
  //nomeDocumentoFinale       String?   @db.VarChar(255) @map("nome_documento_finale")

  createdAt             DateTime? @default(now()) @map("created_at")
  updatedAt             DateTime? @map("updated_at")
  
  operatori             OperatoreServizio[]
  steps                 Step[]
  istanze               Istanza[]
  customerSatisfaction  CustomerSatisfaction?
  ricevuta              Ricevuta?
  ruoli                 ServizioRuoloUser[]

  @@map("servizi")
}

model Ufficio {
  id          Int       @id @default(autoincrement())
  nome        String
  descrizione String?
  email       String?
  telefono    String?
  indirizzo   String?
  attivo      Boolean   @default(true)
  
  servizi     Servizio[]

  @@map("uffici")
}

