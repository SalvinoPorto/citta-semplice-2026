// ============================================

model ProtocolloEmergenzaCounter {
  anno        Int  @id
  progressivo Int  @default(0)

  @@map("protocollo_emergenza_counters")
}

model ProtocolloEmergenza {
  id          Int       @id @default(autoincrement())
  anno        Int       @default(0)
  progressivo Int       @default(0)
  data        DateTime  @default(now())
  tipo        String    // INGRESSO, USCITA
  rettificato Boolean   @default(false)
  istanzaId   Int?      @map("istanza_id")

  @@map("protocollo_emergenza")
}

